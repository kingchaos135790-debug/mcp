{
  "name": "ripgrep-treesitter-qdrant-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Code search and indexing engine over ripgrep + Tree-sitter + Qdrant",
  "main": "dist/cli/run-core.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "index": "tsx src/cli/index-repo.ts",
    "tool": "node dist/cli/run-core.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "1.17.0",
    "fast-glob": "3.3.3",
    "tree-sitter": "0.21.1",
    "tree-sitter-javascript": "0.21.4",
    "tree-sitter-python": "0.21.0",
    "tree-sitter-typescript": "0.23.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "tsx": "4.20.5",
    "typescript": "5.9.2"
  },
  "keywords": [
    "code-search",
    "qdrant",
    "tree-sitter",
    "ripgrep"
  ]
}
